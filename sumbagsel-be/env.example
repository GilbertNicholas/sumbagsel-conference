# Database
# Format: mysql://username:password@host:port/database
# Untuk Docker: gunakan hostname 'db' bukan 'localhost'
# Contoh: mysql://sumbagsel_dev:sumbagsel_dev@db:3306/sumbagsel_dev
DATABASE_URL=mysql://sumbagsel_dev:sumbagsel_dev@localhost:3306/sumbagsel_dev

# JWT Secret Key
# Gunakan string random yang kuat (minimal 32 karakter)
# Generate dengan: openssl rand -base64 32
JWT_SECRET=your-secret-key-change-in-production

# Frontend URL (for CORS)
# URL frontend yang akan mengakses API ini
FRONTEND_URL=http://localhost:3001

# Node Environment
# Options: development, staging, production
NODE_ENV=development

# Port
# Port untuk API server
PORT=3000

# GKDI WhatsApp API (untuk OTP login)
# Base URL API GKDI - https://ticketapi.gkdi.org/api/v2
GKDI_API_URL=https://ticketapi.gkdi.org/api/v2

# OTP Bypass - untuk development (login tanpa kirim OTP)
# Uncomment untuk bypass OTP di admin & peserta login
# OTP_BYPASS_DEV=true
# Token diperoleh dari GET /token, bisa dikosongkan (akan diambil otomatis)
# Atau set token statis jika GKDI menyediakan
# GKDI_APP_TOKEN=

# Redis (untuk Bull queue - email OTP)
REDIS_HOST=localhost
REDIS_PORT=6379

# SMTP (untuk email OTP)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
MAIL_FROM=noreply@sumbagsel2026.gkdi.org

